# -------------------------------------------------------
# GitHub Pages — Frontend Environment Variables
# -------------------------------------------------------
# This frontend is a STATIC site deployed to GitHub Pages.
# It needs a running backend API hosted elsewhere.
#
# Recommended free backend hosts:
#   - Render.com  → https://render.com
#   - Railway.app → https://railway.app
#
# After deploying your backend, paste its public URL below:
REACT_APP_API_URL=https://imap-backend-bub8.onrender.com

# For local development (backend running on localhost):
# REACT_APP_API_URL=http://localhost:4000
