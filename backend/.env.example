# Database (Render.com PostgreSQL or any Postgres provider)
DATABASE_URL=postgresql://user:password@host:5432/inboxious

# Server
PORT=4000

# Set this to your GitHub Pages URL so CORS allows the frontend to call the API.
# Format: https://<YOUR-GITHUB-USERNAME>.github.io
# Do NOT add a trailing slash.
FRONTEND_URL=https://your-username.github.io

# Add one block per email account you want to monitor
# Account 1
ACCOUNT_1_NAME=David
ACCOUNT_1_EMAIL=yourname@gmail.com
ACCOUNT_1_PASSWORD=your_app_password_here
ACCOUNT_1_HOST=imap.gmail.com
ACCOUNT_1_PORT=993

# Account 2 (optional)
# ACCOUNT_2_NAME=Second Account
# ACCOUNT_2_EMAIL=second@gmail.com
# ACCOUNT_2_PASSWORD=your_app_password_here
# ACCOUNT_2_HOST=imap.gmail.com
# ACCOUNT_2_PORT=993

# Poll interval in seconds (minimum 60 recommended)
POLL_INTERVAL=60
